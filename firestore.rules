rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: users
    // Fields: uid, email, displayName, balance, role, createdAt
    //
    // Collection: machines
    // Fields: name, price, dailyIncome, category, imageUrl, stats
    //
    // Collection: users/{userId}/machines
    // Fields: machineId, purchaseDate, lastClaimedAt, status
    //
    // Collection: users/{userId}/transactions
    // Fields: type, amount, currency, method, status, timestamp, details
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && (
        (request.auth.token.email == "amunene460@gmail.com" && request.auth.token.email_verified == true) ||
        (request.auth.token.email == "mugambiallan7@gmail.com" && request.auth.token.email_verified == true) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'balance', 'role', 'displayName', 'createdAt']) &&
             data.uid is string &&
             data.email is string &&
             data.balance is number &&
             data.role in ['user', 'admin'] &&
             data.displayName is string &&
             data.createdAt is string &&
             data.displayName.size() <= 100 &&
             data.email.size() <= 100;
    }

    function isValidMachine(data) {
      return data.keys().hasAll(['name', 'price', 'dailyIncome', 'category']) &&
             data.name is string && data.name.size() <= 100 &&
             data.price is number && data.price >= 0 &&
             data.dailyIncome is number && data.dailyIncome >= 0 &&
             data.category in ['tech', 'electronics', 'high-end', 'vip'];
    }

    function isValidTransaction(data) {
      return data.keys().hasAll(['type', 'amount', 'status', 'timestamp']) &&
             data.type in ['deposit', 'withdrawal', 'purchase'] &&
             data.amount is number &&
             data.status in ['pending', 'completed', 'failed'] &&
             data.timestamp is string;
    }

    // Rules
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if (isOwner(userId) && isValidUser(request.resource.data) && (request.resource.data.role == resource.data.role || isAdmin())) || isAdmin();
      allow delete: if isAdmin();

      // Subcollections
      match /machines/{machineId} {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if isOwner(userId) || isAdmin();
      }
      
      match /transactions/{txId} {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if isOwner(userId) || isAdmin();
      }
    }

    // Explicitly allow admins to list users
    match /users {
      allow list: if isAdmin();
    }

    match /machines/{machineId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /system/stats {
      allow read: if true;
      allow write: if isAdmin();
      allow update: if isAuthenticated();
    }

    match /test/connection {
      allow read: if true;
    }
  }
}
